{
  "name": "warisan-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "NODE_ENV=development knex migrate:latest",
    "migrate:prod": "NODE_ENV=production knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "NODE_ENV=development knex seed:run",
    "seed:prod": "NODE_ENV=production knex seed:run",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^5.1.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "slugify": "^1.6.6",
    "sanitize-html": "^2.14.0",
    "sharp": "^0.33.0",
    "ioredis": "^5.4.0",
    "openai": "^4.78.0",
    "dotenv": "^16.4.0",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/express": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/sanitize-html": "^2.13.0",
    "@types/cookie-parser": "^1.4.7",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.0.0"
  }
}