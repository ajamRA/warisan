# Render Backend Environment Variables
# Copy these to Render dashboard → Environment

# Supabase Database (get from Supabase → Settings → Database → Connection string)
# Use "Transaction" mode connection string
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Auth (Render auto-generates these, or set your own)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# CORS (your Netlify frontend URL)
CORS_ORIGIN=https://your-app.netlify.app

# AI (optional)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# App
NODE_ENV=production
PORT=10000